rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Enterprise Admin Support (Optional but good) ---
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) 
        && data.uid is string 
        && data.email is string 
        && data.email.size() < 256
        && data.uid == request.auth.uid;
    }

    function isValidRepo(data) {
      return data.keys().hasAll(['ownerId', 'title', 'type'])
        && data.ownerId == request.auth.uid
        && data.title is string && data.title.size() <= 100
        && data.type in ['snippet', 'repo', 'asset']
        && (!('code' in data) || (data.code is string && data.code.size() <= 1048576)); // 1MB code limit
    }

    function isValidAudit(data, repoId) {
      return data.keys().hasAll(['repoId', 'status'])
        && data.repoId == repoId
        && data.status in ['safe', 'warning', 'dangerous'];
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'title', 'content'])
        && data.authorId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 10000;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // We might need to search users
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'githubUrl', 'stats']);
    }

    // Repositories
    match /repositories/{repoId} {
      allow read: if true; // Repos are public
      allow create: if isEmailVerified() && isValidRepo(incoming()) && isValidId(repoId);
      allow update: if (isOwner(existing().ownerId) || isAdmin())
        && isValidRepo(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'techStack', 'code', 'type', 'stars', 'isAudited', 'auditStatus', 'updatedAt']);
      
      // Subcollection: Audits
      match /audits/{auditId} {
        allow read: if true;
        // Only the owner of the repo or an admin can trigger/save an audit (audit is done by client but verified by presence of auth)
        allow create: if isEmailVerified() && isValidAudit(incoming(), repoId) && (isOwner(get(/databases/$(database)/documents/repositories/$(repoId)).data.ownerId) || isAdmin());
      }
    }

    // Posts
    match /posts/{postId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidPost(incoming()) && isValidId(postId);
      allow update: if (isOwner(existing().authorId) || isAdmin())
        && isValidPost(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'tags', 'likes', 'commentCount']);
    }

    // Admins path
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
